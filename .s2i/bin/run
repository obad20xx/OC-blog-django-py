#!/bin/bash

set -eo pipefail

# If a wheelhouse cache directory exists, the repository was used as
# input to a wheelhouse build, to build Python wheels for required packages.
# In this case fall through to executing the original 'run' script.

if [ -d /opt/app-root/wheelhouse ]; then
    exec /usr/libexec/s2i/run
fi

# Run the deploy action hook if present.

if [ -f /opt/app-root/src/.s2i/action_hooks/deploy ]; then
    source /opt/app-root/src/.s2i/action_hooks/deploy_env 2>/dev/null || true
    echo " -----> Running deploy action hook."
    bash /opt/app-root/src/.s2i/action_hooks/deploy
fi

# Run the original S2I run script.

exec /usr/libexec/s2i/run

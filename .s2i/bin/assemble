#!/bin/bash

set -eo pipefail

# If a wheelhouse cache directory exists, the repository is being used as
# input to a wheelhouse build, to build Python wheels for required packages.
# In this case fall through to executing the original 'assemble' script.

if [ -d /opt/app-root/wheelhouse ]; then
    exec /opt/app-root/s2i/assemble
fi

# Run the original S2I assemble script.

/opt/app-root/s2i/assemble

# Run the pre_build action hook if present.

if [ -f /opt/app-root/src/.s2i/action_hooks/pre_build ]; then
    source /opt/app-root/src/.s2i/action_hooks/build_env 2>/dev/null || true
    echo " -----> Running pre_build action hook."
    bash /opt/app-root/src/.s2i/action_hooks/pre_build
fi

# Run the build action hook if present.

if [ -f /opt/app-root/src/.s2i/action_hooks/build ]; then
    source /opt/app-root/src/.s2i/action_hooks/build_env 2>/dev/null || true
    echo " -----> Running build action hook."
    bash /opt/app-root/src/.s2i/action_hooks/build
fi
